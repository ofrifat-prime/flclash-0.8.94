#!/bin/sh

REAL_OHPM=${REAL_OHPM:-/tmp/ohcommandline-tools-mac/oh-command-line-tools/bin/ohpm}

if [ ! -x "$REAL_OHPM" ]; then
  echo "REAL_OHPM is not executable: $REAL_OHPM" >&2
  exit 1
fi

set -- "$@"
TARGET_PATH=""

link_dependency_modules() {
  project_root=$1
  dependency_modules=$2

  if [ ! -d "$dependency_modules" ]; then
    return
  fi

  for link_path in "$project_root/oh_modules" "$project_root/ohos/oh_modules"; do
    parent_dir=$(dirname "$link_path")
    mkdir -p "$parent_dir"
    rm -rf "$link_path"
    ln -s "$dependency_modules" "$link_path"
  done
}

cleanup_dependency_links() {
  project_root=$1

  for link_path in "$project_root/oh_modules" "$project_root/ohos/oh_modules"; do
    if [ -L "$link_path" ]; then
      rm -f "$link_path"
    fi
  done
}

if [ "$1" = "install" ] || [ "$1" = "i" ]; then
  shift
  args=""
  skip_next=0
  for arg in "$@"; do
    if [ "$skip_next" = "1" ]; then
      TARGET_PATH="$arg"
      skip_next=0
      continue
    fi
    if [ "$arg" = "--target_path" ]; then
      skip_next=1
      continue
    fi
    if [ "$arg" != "--all" ]; then
      args="$args \"$arg\""
    fi
  done
  eval "set -- install $args"
fi

if [ -n "$TARGET_PATH" ]; then
  if [ ! -d "$TARGET_PATH" ]; then
    echo "target path does not exist: $TARGET_PATH" >&2
    exit 1
  fi
  SOURCE_HAR_DIR=$(cd "$TARGET_PATH/../../har" 2>/dev/null && pwd)
  if [ -n "$SOURCE_HAR_DIR" ] && [ -d "$SOURCE_HAR_DIR" ]; then
    mkdir -p "$TARGET_PATH/har"
    cp -f "$SOURCE_HAR_DIR"/*.har "$TARGET_PATH/har/" 2>/dev/null || true
  fi
  PROJECT_ROOT=$(cd "$TARGET_PATH/../../.." 2>/dev/null && pwd)
  if [ -n "$PROJECT_ROOT" ]; then
    cleanup_dependency_links "$PROJECT_ROOT"
  fi
  cd "$TARGET_PATH" || exit 1
fi

"$REAL_OHPM" "$@"
status=$?

if [ "$status" -eq 0 ] && [ -n "$TARGET_PATH" ] && [ -n "$PROJECT_ROOT" ]; then
  link_dependency_modules "$PROJECT_ROOT" "$TARGET_PATH/oh_modules"
fi

exit "$status"
